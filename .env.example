# Vercel 환경변수 (프로젝트 Settings → Environment Variables 에 등록)
# 로컬 테스트 시에는 `vercel dev` 실행 후 아래 값을 .env.local 로 복사해서 사용하세요.

# OpenAI API 키 (필수) — 브라우저에는 절대 노출되지 않고 서버 함수에서만 사용됩니다.
OPENAI_API_KEY=sk-...

# 사용할 모델 (선택, 기본값 gpt-5.4-mini)
OPENAI_MODEL=gpt-5.4-mini

# --- Supabase (사주 추천 데이터 저장용) ---
# 미설정 시 저장은 건너뛰고 추천 기능은 정상 동작합니다.
# service_role 키는 RLS를 우회하는 비밀 키이므로 서버 환경변수에만 두고 절대 노출하지 마세요.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 저장할 테이블명 (선택, 기본값 saju_logs)
SUPABASE_TABLE=saju_logs
